# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/Documentation

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
.env.test

# Drizzle migrations — SQL files + journal + snapshots must all be committed
# Snapshots are required by drizzle-kit generate to detect schema changes

# vercel
.vercel

# test artifacts
/test-results/
/playwright-report/
/blob-report/
/coverage/

# uploads (user-uploaded images, served via API)
/uploads/
/data

# typescript
*.tsbuildinfo
next-env.d.ts
