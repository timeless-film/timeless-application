# =============================================================================
# TIMELESS — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Base de données (Scaleway Managed PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/timeless

# Better Auth
BETTER_AUTH_SECRET=          # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# TMDB
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=

# Scaleway Object Storage (DCPs)
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_BUCKET_NAME=timeless-dcps
SCALEWAY_REGION=fr-par
SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud

# Exchange Rates (pour l'affichage multi-devises)
EXCHANGE_RATES_API_KEY=

# Email (Resend)
EMAIL_FROM=Timeless <hello@timeless.film>
