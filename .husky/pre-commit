npx lint-staged

# ── Drizzle migration integrity check ─────────────────────────────────────────
# Verify that every migration in the journal has a matching snapshot file.
# Missing snapshots cause drizzle-kit generate to produce duplicate migrations.
echo ""
echo "Checking Drizzle snapshot integrity..."

JOURNAL="drizzle/meta/_journal.json"
if [ -f "$JOURNAL" ]; then
  MISSING_SNAPSHOTS=""
  for idx in $(node -e "const j=require('./$JOURNAL'); j.entries.forEach(e => console.log(e.idx.toString().padStart(4,'0')))"); do
    if [ ! -f "drizzle/meta/${idx}_snapshot.json" ]; then
      MISSING_SNAPSHOTS="${MISSING_SNAPSHOTS} ${idx}"
    fi
  done

  if [ -n "$MISSING_SNAPSHOTS" ]; then
    echo ""
    echo "❌ Missing Drizzle snapshot file(s):${MISSING_SNAPSHOTS}"
    echo "   Every migration in drizzle/meta/_journal.json must have a matching snapshot."
    echo "   Use 'pnpm db:generate' to create migrations — never add them manually."
    exit 1
  fi
fi

# ── Drizzle migration drift check ─────────────────────────────────────────────
# We check only what is STAGED (what will actually land in the commit).
# Strategy: stash unstaged changes -> run generate on staged state -> restore stash.
# If a migration is needed, stage drizzle/ automatically so the commit stays in sync.
echo ""
echo "Checking Drizzle schema (staged files only)..."

# Stash unstaged tracked + untracked changes, keep the index (staged files)
git stash push --keep-index --include-untracked --quiet -m "drizzle-pre-commit-check" 2>/dev/null
STASH_RESULT=$?

# Run generate against staged state — no DB connection needed, placeholder URL is enough
DATABASE_URL="postgresql://localhost/placeholder" pnpm exec drizzle-kit generate </dev/null 2>&1
DRIZZLE_EXIT=$?

# Restore working tree before any exit
if [ "$STASH_RESULT" -eq 0 ]; then
  git stash pop --quiet 2>/dev/null
fi

if [ "$DRIZZLE_EXIT" -ne 0 ]; then
  echo ""
  echo "❌ drizzle-kit generate failed."
  echo "   Run: pnpm db:generate"
  echo "   Then: git add drizzle/"
  exit 1
fi

# Check if generate produced new or modified files in drizzle/
NEW_FILES=$(git ls-files --others --exclude-standard drizzle/ 2>/dev/null)
MODIFIED=$(git diff drizzle/ 2>/dev/null)

if [ -n "$NEW_FILES" ] || [ -n "$MODIFIED" ]; then
  echo ""
  echo "⚠️  Drizzle migration files were generated automatically."
  echo "   Staging updated drizzle/ files for this commit..."
  echo ""
  git add drizzle/
  echo "✅ Added drizzle migration files to the commit."
fi

echo "✅ Drizzle migrations are up to date."
